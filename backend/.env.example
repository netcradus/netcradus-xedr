# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5433/netcradxdr

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_minimum_32_chars_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
ALLOWED_ORIGINS=https://your-frontend-domain.com

# ── Platform bootstrap (created on first startup) ────────────────────────────
PLATFORM_ADMIN_EMAIL=admin@yourcompany.com
PLATFORM_ADMIN_PASSWORD=CHANGE_ME_strong_password

# ── Task queue ────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=noreply@yourcompany.com
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=NetcradXDR <noreply@yourcompany.com>

# ── AI (Groq) ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_CHANGE_ME

# ── Object storage (optional) ────────────────────────────────────────────────
STORAGE_BUCKET=

# ── Threat intelligence API keys (optional — set per-tenant in UI) ───────────
# These are global fallbacks; per-tenant keys set in Settings override them.
# VIRUSTOTAL_API_KEY=
# ABUSEIPDB_API_KEY=
# OTX_API_KEY=
