# Copy to backend/.env and fill in your values.
# Source of truth for every variable below is backend/app/core/config.py —
# if this file and that one ever disagree, config.py wins.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5433/netcradxdr

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# The server refuses to start with a placeholder value here unless DEBUG=true.
SECRET_KEY=80b7815e3d8196a41efe19035f563fc490fbc8000ebdc448c6af4ce568edfbb3
JWT_ALGORITHM=HS256

# Access token lifetime (short — refresh token handles renewal)
ACCESS_TOKEN_EXPIRE_MINUTES=15
# Refresh token lifetime, stored in an httpOnly cookie
REFRESH_TOKEN_EXPIRE_DAYS=30

# Set true only for local development — relaxes some checks that are unsafe
# on the internet (insecure SECRET_KEY allowed, open agent registration).
DEBUG=false

# ── App ───────────────────────────────────────────────────────────────────────
# Frontend URL — used to build links inside emails
APP_URL=http://localhost:5173

# CORS — comma-separated list of origins allowed to call the API.
# Only matters for a client that bypasses the same-origin nginx/Vite proxy
# (see docs/01-system-architecture.md §2) — the normal dashboard flow doesn't
# need this to include its own origin.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Agents ────────────────────────────────────────────────────────────────────
# Shared secret every endpoint agent must present to enroll. Leave blank +
# DEBUG=false to disable new agent registration entirely (safe default).
AGENT_REGISTRATION_TOKEN=

# ── Platform bootstrap (created automatically on first startup) ──────────────
# This account manages the platform itself, not any single customer's data.
PLATFORM_ADMIN_EMAIL=admin@netcradus.com
PLATFORM_ADMIN_PASSWORD=admin123@

# ── Task queue (Celery / Redis) ────────────────────────────────────────────────
# Leave blank to run background tasks in-process instead (fine for one small
# deployment — see docs/03-infrastructure-plan.md). If set, also run:
#   celery -A app.core.celery_app worker --loglevel=info
#   celery -A app.core.celery_app beat   --loglevel=info
REDIS_URL=redis://localhost:6379/0

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# This is the platform's own outgoing email account — never per-customer.
# Leave SMTP_HOST blank to skip email verification entirely (dev-friendly;
# do this only for internal/test use, not a public-facing deployment).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=noreply@yourcompany.com
SMTP_PASS=CHANGE_ME
SMTP_FROM=noreply@yourcompany.com

# ── AI (Groq) ─────────────────────────────────────────────────────────────────
# Powers the AI Query Assistant. Get a free key at console.groq.com.
# Leave blank to disable just that one feature — nothing else depends on it.
GROQ_API_KEY=gsk_CHANGE_ME

# ── Object storage (optional) ────────────────────────────────────────────────
# S3-compatible (AWS S3 / MinIO / R2 / Spaces). Leave STORAGE_BUCKET blank to
# fall back to local filesystem storage (./local_storage by default) — fine
# for a single backend instance, not for multiple replicas without a shared
# volume. See config.py for STORAGE_ENDPOINT_URL / STORAGE_REGION /
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / STORAGE_LOCAL_DIR if you need
# the rest of the S3 configuration.
STORAGE_BUCKET=

# ── Threat intelligence enrichment ────────────────────────────────────────────
# IMPORTANT: VirusTotal / AbuseIPDB / OTX keys are NOT read from environment
# variables anywhere in this codebase — they are per-tenant only, set inside
# the product under Settings > Threat Intelligence Keys
# (backend/app/models/threat_feed_config.py). There is no global/.env
# fallback despite what older versions of this file implied. Do not add
# VIRUSTOTAL_API_KEY / ABUSEIPDB_API_KEY / OTX_API_KEY here — they will be
# silently ignored.
