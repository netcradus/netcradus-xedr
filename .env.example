# Copy to backend/.env and fill in your values

DATABASE_URL=postgresql://postgres:postgres@localhost:5433/sentryxdr
SECRET_KEY=change-this-to-a-random-64-char-string
JWT_ALGORITHM=HS256

# Access token lifetime (short — refresh token handles renewal)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token lifetime stored in httpOnly cookie
REFRESH_TOKEN_EXPIRE_DAYS=30

# Optional — leave blank to disable agent registration token check
AGENT_REGISTRATION_TOKEN=

# Required for AI features — get your key at console.groq.com
GROQ_API_KEY=gsk_...

# Required for Threat Intel enrichment
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=

# SMTP — platform system email for verification and password reset
# This is Netcradus's own email address — set once by the platform operator, never per-customer
# Leave blank to disable (users can still log in without verifying)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com

# Frontend URL — used in email links
APP_URL=http://localhost:5173

# CORS — comma-separated list of origins allowed to call the API
# Production example: ALLOWED_ORIGINS=https://app.sentryxdr.com
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Redis — broker for Celery background tasks (IOC enrichment, notifications)
# Leave blank or omit to fall back to threading (development only)
REDIS_URL=redis://localhost:6379/0

# Platform Admin — SaaS operator account created automatically on first startup
# Set these once; the account is never tied to a customer tenant
PLATFORM_ADMIN_EMAIL=admin@netcradus.com
PLATFORM_ADMIN_PASSWORD=change-this-strong-password
