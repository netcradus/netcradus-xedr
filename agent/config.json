{
  "server_url": "http://192.168.1.21:8888/api/v1",
  "agent_token": "",
  "registration_token": "",
  "tenant_api_key": "",
  "agent_version": "1.0.0",
  "poll_interval": 10,
  "update_check_interval": 6,
  "log_sources": {
    "syslog": {
      "enabled": true,
      "paths": [
        "/var/log/syslog",
        "/var/log/auth.log",
        "/var/log/secure",
        "/var/log/messages"
      ]
    },
    "windows_event": {
      "enabled": true,
      "channels": ["Security", "System", "Application"]
    },
    "web_logs": {
      "enabled": false,
      "sources": [
        {"type": "apache", "path": "/var/log/apache2/access.log"},
        {"type": "nginx",  "path": "/var/log/nginx/access.log"},
        {"type": "iis",    "path": "C:/inetpub/logs/LogFiles/W3SVC1/u_ex*.log"}
      ]
    },
    "app_logs": {
      "enabled": false,
      "paths": [
        {"path": "/var/log/myapp/app.log", "label": "myapp"}
      ]
    }
  }
}
